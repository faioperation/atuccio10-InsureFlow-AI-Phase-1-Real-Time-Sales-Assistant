# ============================================================
# InsureFlow Orchestrator – Environment Configuration
# ============================================================
# Copy this file to .env and fill in ALL required values.
# NEVER commit the real .env file to version control.
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
# Port the FastAPI / Uvicorn Orchestrator server listens on.
# Twilio webhook must point to this port.
# Required: No   Default: 5050
PORT=5050

# ── TWILIO ───────────────────────────────────────────────────
# Your Twilio phone number (E.164 format: +1XXXXXXXXXX).
# Used as callerId when bridging outbound leg.
# Required: YES
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# The destination phone number the call is bridged to.
# This is the sales agent's real phone number.
# Required: YES
TARGET_PHONE_NUMBER=+1XXXXXXXXXX

# Twilio Account SID (used if placing outbound calls in future).
# Required: No
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token (used if placing outbound calls in future).
# Required: No
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── DEEPGRAM (Real-time Transcription) ───────────────────────
# Deepgram API key for live speech-to-text streaming.
# Model: nova-2, Language: en-US, mulaw@8000 Hz (Twilio format).
# Required: YES
DEEPGRAM_API_KEY=your-deepgram-api-key
