# ============================================================
# InsureFlow AI Agent – Environment Configuration
# ============================================================
# Copy this file to .env and fill in ALL required values.
# NEVER commit the real .env file to version control.
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
# Port the FastAPI / Uvicorn server listens on.
# Required: No   Default: 5051
AGENT_PORT=5051

# ── ORCHESTRATOR CONNECTION ──────────────────────────────────
# WebSocket URL of the InsureFlow Orchestrator.
# The Agent connects here on startup to receive live transcripts.
# Required: YES
# Docker example: ws://orchestrator:5050/transcript-stream
# Local  example: ws://localhost:5050/transcript-stream
ORCHESTRATOR_WS_URL=ws://localhost:5050/transcript-stream

# ── OPENAI ───────────────────────────────────────────────────
# Used by: NLUManager (gpt-4o-mini + text-embedding-3-small),
#          EntityExtractor (gpt-4o-mini),
#          SentimentAnalyzer (gpt-4o-mini),
#          ResponseEngine (gpt-4o-mini)
# Required: YES
OPENAI_API_KEY=sk-proj-...

# ── PINECONE (Vector DB / RAG) ───────────────────────────────
# Required: YES
PINECONE_API_KEY=pcsk_...

# Name of the Pinecone index containing the sales-playbook embeddings.
# Required: YES
PINECONE_INDEX_NAME=insureflow-tactics

# Namespace within the Pinecone index.
# Required: No   Default: sales-playbook-v1
PINECONE_NAMESPACE=sales-playbook-v1

# ── REDIS (Conversation Memory) ──────────────────────────────
# For Redis Cloud: use the endpoint hostname provided by the console.
# For Docker Compose: use the service name (e.g., redis).
# Required: YES
REDIS_HOST=your-redis-host.redis.cloud

# Redis port. Standard Redis: 6379. Redis Cloud: varies.
# Required: YES
REDIS_PORT=6379

# Redis AUTH password. Leave blank only if auth is disabled.
# Required: YES (for any non-local Redis)
REDIS_PASSWORD=your-redis-password

# ── PROCESSING TUNING ────────────────────────────────────────
# Silence window (seconds). Buffer accumulates transcript chunks
# for this many seconds of silence before triggering AI pipeline.
# Required: No   Default: 3
CHUNK_BUFFER_SECONDS=3
